@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="auth-card animate-fade-in">
                    <div class="auth-header">
                        <h2>Welcome Back</h2>
                        <p>Sign in to your DevWithPiyush account</p>
                    </div>
                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="Email" class="form-label-custom">Email</label>
                            <input asp-for="Email" class="form-control-custom" placeholder="you@example.com" autofocus />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="Password" class="form-label-custom">Password</label>
                            <input asp-for="Password" class="form-control-custom" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label text-muted">Remember me</label>
                        </div>

                        <button type="submit" class="btn btn-primary-custom btn-lg w-100 mb-3">
                            Sign In <i class="bi bi-arrow-right"></i>
                        </button>

                        <p class="text-center text-muted">
                            Don't have an account?
                            <a asp-action="Register" class="auth-link">Create one</a>
                        </p>
                    </form>

                    <div class="auth-demo-info">
                        <p class="small text-muted mb-1"><strong>Demo Credentials:</strong></p>
                        <p class="small text-muted mb-0">Admin: admin@devwithpiyush.com / Admin@123456</p>
                        <p class="small text-muted mb-0">Student: student@devwithpiyush.com / Student@123456</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
