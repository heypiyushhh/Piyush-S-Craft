@model CourseDetailViewModel
@{
    ViewData["Title"] = Model.Course.Title;
}

<section class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb" class="animate-fade-in">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
                <li class="breadcrumb-item active">@Model.Course.Title</li>
            </ol>
        </nav>
    </div>
</section>

<section class="section-padding" style="padding-top: 1rem;">
    <div class="container">
        <div class="row g-4">
            <!-- Course Info -->
            <div class="col-lg-8">
                <div class="animate-slide-up">
                    <span class="course-level-badge @Model.Course.Level.ToString().ToLower() mb-3 d-inline-block">
                        @Model.Course.Level
                    </span>
                    <h1 class="mb-3" style="font-size: 2.2rem; font-weight: 800;">@Model.Course.Title</h1>
                    <p class="lead text-muted mb-4">@Model.Course.ShortDescription</p>

                    <div class="d-flex gap-4 mb-4 flex-wrap">
                        <div class="course-detail-stat">
                            <i class="bi bi-clock"></i>
                            <div>
                                <span class="stat-val">@Model.Course.DurationHours hours</span>
                                <span class="stat-lbl">Duration</span>
                            </div>
                        </div>
                        <div class="course-detail-stat">
                            <i class="bi bi-bar-chart"></i>
                            <div>
                                <span class="stat-val">@Model.Course.Level</span>
                                <span class="stat-lbl">Difficulty</span>
                            </div>
                        </div>
                        <div class="course-detail-stat">
                            <i class="bi bi-people"></i>
                            <div>
                                <span class="stat-val">@Model.Course.EnrollmentCount</span>
                                <span class="stat-lbl">Enrolled</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-custom">
                        <h4 class="mb-3">About This Course</h4>
                        <p style="line-height: 1.8;">@Model.Course.Description</p>
                    </div>

                    <div class="card-custom mt-4 animate-slide-up" style="animation-delay: 0.1s;">
                        <h4 class="mb-4">Course Curriculum</h4>
                        <div class="accordion" id="curriculumAccordion">
                            @foreach (var cSection in Model.Course.Sections)
                            {
                                <div class="accordion-item mb-2 border shadow-sm rounded overflow-hidden">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#sec-@cSection.Id">
                                            <div class="d-flex justify-content-between w-100 pe-3">
                                                <span class="fw-bold">@cSection.Title</span>
                                                <span class="text-muted small">@cSection.Lessons.Count Lessons</span>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="sec-@cSection.Id" class="accordion-collapse collapse show">
                                        <div class="accordion-body p-0">
                                            <ul class="list-group list-group-flush">
                                                @foreach (var lesson in cSection.Lessons)
                                                {
                                                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                                        <span><i class="bi bi-play-circle me-2 text-primary"></i> @lesson.Title</span>
                                                        @if (Model.IsEnrolled)
                                                        {
                                                            <a asp-action="Watch" asp-route-slug="@Model.Course.Slug" asp-route-lessonId="@lesson.Id" class="btn btn-sm btn-primary-custom px-3">Watch</a>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted" title="Enroll to watch">
                                                                <i class="bi bi-lock-fill"></i>
                                                            </span>
                                                        }
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        @if (!Model.IsEnrolled)
                        {
                            <div class="text-center mt-4 p-3 bg-light rounded border border-dashed">
                                <p class="mb-2 text-muted">Enroll in this course to unlock all lessons and start learning.</p>
                                <button type="button" onclick="document.querySelector('#enroll-btn')?.scrollIntoView({behavior: 'smooth'})" class="btn btn-sm btn-outline-primary">
                                    Unlock Now
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="card-custom sticky-top" style="top: 100px;">
                    <div class="course-image mb-4" style="border-radius: 8px; height: 180px;">
                        <i class="bi bi-play-circle course-play-icon"></i>
                    </div>

                    <div class="text-center mb-4">
                        <span class="course-detail-price">
                            @(Model.Course.Price == 0 ? "Free" : "₹" + Model.Course.Price.ToString("N0"))
                        </span>
                    </div>

                    @if (Model.IsEnrolled)
                    {
                        <div class="text-center">
                            <span class="badge bg-success fs-6 mb-3 p-2">
                                <i class="bi bi-check-circle me-1"></i> Already Enrolled
                            </span>
                            <a asp-controller="Student" asp-action="Dashboard" class="btn btn-primary-custom w-100">
                                Go to Dashboard
                            </a>
                        </div>
                    }
                    else if (Model.IsAuthenticated)
                    {
                        <form asp-controller="Course" asp-action="Enroll" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="courseId" value="@Model.Course.Id" />
                            <button id="enroll-btn" type="submit" class="btn btn-primary-custom btn-lg w-100">
                                Enroll Now <i class="bi bi-arrow-right"></i>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary-custom btn-lg w-100">
                            Login to Enroll <i class="bi bi-arrow-right"></i>
                        </a>
                    }

                    <div class="mt-4">
                        <div class="d-flex justify-content-between text-muted small mb-2">
                            <span><i class="bi bi-award me-1"></i> Certificate</span>
                            <span>@(Model.Course.IssuesCertificate ? "Yes" : "No")</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted small mb-2">
                            <span><i class="bi bi-infinity me-1"></i> Lifetime Access</span>
                            <span>Yes</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted small">
                            <span><i class="bi bi-translate me-1"></i> Language</span>
                            <span>English + Hindi</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
