@model CoursePlayerViewModel
@{
    ViewData["Title"] = Model.Course.Title;
}

<div class="container-fluid py-4 bg-dark text-light" style="min-height: 90vh;">
    <div class="row">
        <!-- Sidebar: Course Content -->
        <div class="col-lg-3 border-end border-secondary">
            <h4 class="mb-4">Course Content</h4>
            <div class="accordion accordion-flush" id="courseAccordion">
                @foreach (var cSection in Model.Course.Sections)
                {
                    <div class="accordion-item bg-dark text-light border-secondary">
                        <h2 class="accordion-header">
                            <button class="accordion-button bg-dark text-light collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#section-@cSection.Id">
                                @cSection.Title
                            </button>
                        </h2>
                        <div id="section-@cSection.Id" class="accordion-collapse collapse show">
                            <div class="accordion-body p-0">
                                <ul class="list-group list-group-flush">
                                    @foreach (var lesson in cSection.Lessons)
                                    {
                                        <li class="list-group-item bg-dark border-secondary">
                                            <a asp-action="Watch" asp-route-slug="@Model.Course.Slug" asp-route-lessonId="@lesson.Id" 
                                               class="text-decoration-none @(Model.CurrentLesson?.Id == lesson.Id ? "text-warning fw-bold" : "text-light")">
                                                @if (lesson.IsCompleted)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-play-circle me-2"></i>
                                                }
                                                @lesson.Title
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Main: Video Player -->
        <div class="col-lg-9">
            @if (Model.CurrentLesson != null)
            {
                <div class="ps-lg-4">
                    <h2 class="mb-3">@Model.CurrentLesson.Title</h2>
                    
                    @if (!string.IsNullOrEmpty(Model.CurrentLesson.YouTubeVideoId))
                    {
                        <div class="ratio ratio-16x9 mb-4 shadow-lg bg-black" style="border: 1px solid #444; border-radius: 8px; overflow: hidden;">
                            <iframe src="https://www.youtube.com/embed/@Model.CurrentLesson.YouTubeVideoId" 
                                    title="@Model.CurrentLesson.Title"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                    allowfullscreen></iframe>
                        </div>

                        <div class="d-flex justify-content-between align-items-center bg-secondary bg-opacity-25 p-3 rounded mb-3">
                            <div>
                                 <p class="mb-1 small text-light-50">Watch this video to complete the lesson.</p>
                                 <a href="https://www.youtube.com/watch?v=@Model.CurrentLesson.YouTubeVideoId" target="_blank" class="small text-warning text-decoration-none">
                                     <i class="bi bi-box-arrow-up-right me-1"></i> Watch on YouTube directly
                                 </a>
                            </div>
                            @if (!Model.CurrentLesson.IsCompleted)
                            {
                                <form asp-action="CompleteLesson" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="lessonId" value="@Model.CurrentLesson.Id" />
                                    <input type="hidden" name="slug" value="@Model.Course.Slug" />
                                    <button type="submit" class="btn btn-warning btn-sm px-4">
                                        <i class="bi bi-check2"></i> Mark as Completed
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-success p-2">
                                    <i class="bi bi-check-circle"></i> Completed
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info bg-secondary border-0 text-light py-5 text-center">
                            <i class="bi bi-info-circle display-4 mb-3 d-block"></i>
                            <p class="mb-0">This lesson has no video content.</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-journal-x display-1 text-secondary mb-4"></i>
                    <h3>No Lesson Selected</h3>
                    <p class="text-muted">Please select a lesson from the sidebar to start learning.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .accordion-button::after { filter: invert(1); }
        .list-group-item:hover { background-color: #333 !important; }
        .accordion-button:not(.collapsed) { color: #ffc107; background-color: #212529; }
    </style>
}
