@{
    ViewData["Title"] = "Error";
}

<section class="auth-section">
    <div class="container text-center">
        <div class="animate-fade-in">
            <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: var(--danger);"></i>
            <h2 class="mt-3">Something went wrong</h2>
            <p class="text-muted">An unexpected error occurred. Please try again later.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-custom">
                <i class="bi bi-house me-2"></i> Go Home
            </a>
        </div>
    </div>
</section>
