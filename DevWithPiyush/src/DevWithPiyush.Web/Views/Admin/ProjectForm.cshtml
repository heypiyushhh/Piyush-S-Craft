@model ProjectDto
@{
    ViewData["Title"] = Model.Id == 0 ? "Create Project" : "Edit Project";
    ViewData["AdminPage"] = true;
}

<section class="page-header">
    <div class="container">
        <h1 class="page-title animate-slide-up">@(Model.Id == 0 ? "Create New Project" : "Edit Project")</h1>
    </div>
</section>

<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card-custom">
                    <form asp-action="SaveProject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="Title" class="form-label-custom">Project Title</label>
                            <input asp-for="Title" class="form-control-custom" placeholder="e.g. E-Commerce Platform" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="Description" class="form-label-custom">Description</label>
                            <textarea asp-for="Description" class="form-control-custom" rows="5" placeholder="Detailed project description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="Technologies" class="form-label-custom">Technologies (comma separated)</label>
                            <input asp-for="Technologies" class="form-control-custom" placeholder="e.g. ASP.NET Core, EF Core, SQL Server, Bootstrap" />
                            <span asp-validation-for="Technologies" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label asp-for="ImageUrl" class="form-label-custom">Image URL</label>
                                    <input asp-for="ImageUrl" class="form-control-custom" placeholder="/images/projects/project1.jpg" />
                                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label asp-for="DisplayOrder" class="form-label-custom">Display Order</label>
                                    <input asp-for="DisplayOrder" type="number" class="form-control-custom" />
                                    <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label asp-for="LiveUrl" class="form-label-custom">Live Demo URL</label>
                                    <input asp-for="LiveUrl" class="form-control-custom" placeholder="https://..." />
                                    <span asp-validation-for="LiveUrl" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label asp-for="GitHubUrl" class="form-label-custom">GitHub URL</label>
                                    <input asp-for="GitHubUrl" class="form-control-custom" placeholder="https://github.com/..." />
                                    <span asp-validation-for="GitHubUrl" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsVisible" class="form-check-input" />
                            <label asp-for="IsVisible" class="form-check-label">Visible on portfolio</label>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary-custom btn-lg">
                                <i class="bi bi-check-lg me-1"></i> @(Model.Id == 0 ? "Create Project" : "Save Changes")
                            </button>
                            <a asp-action="Projects" class="btn btn-outline-custom btn-lg">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
