@model CourseDto
@{
    ViewData["Title"] = Model.Id == 0 ? "Create Course" : "Edit Course";
    ViewData["AdminPage"] = true;
}

<section class="page-header">
    <div class="container">
        <h1 class="page-title animate-slide-up">@(Model.Id == 0 ? "Create New Course" : "Edit Course")</h1>
    </div>
</section>

<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card-custom">
                    <form asp-action="SaveCourse" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="Title" class="form-label-custom">Course Title</label>
                            <input asp-for="Title" class="form-control-custom" placeholder="e.g. ASP.NET Core Masterclass" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="ShortDescription" class="form-label-custom">Short Description</label>
                            <input asp-for="ShortDescription" class="form-control-custom" placeholder="One-liner about the course" />
                            <span asp-validation-for="ShortDescription" class="text-danger small"></span>
                        </div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="Description" class="form-label-custom">Full Description</label>
                            <textarea asp-for="Description" class="form-control-custom" rows="5" placeholder="Detailed course description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <div class="form-group-custom">
                                    <label asp-for="Level" class="form-label-custom">Level</label>
                                    <select asp-for="Level" asp-items="Html.GetEnumSelectList<CourseLevel>()" class="form-control-custom"></select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group-custom">
                                    <label asp-for="DurationHours" class="form-label-custom">Duration (hours)</label>
                                    <input asp-for="DurationHours" type="number" class="form-control-custom" min="1" />
                                    <span asp-validation-for="DurationHours" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group-custom">
                                    <label asp-for="Price" class="form-label-custom">Price (₹)</label>
                                    <input asp-for="Price" type="number" class="form-control-custom" min="0" step="1" />
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group-custom mb-3">
                            <label asp-for="ImageUrl" class="form-label-custom">Image URL (optional)</label>
                            <input asp-for="ImageUrl" class="form-control-custom" placeholder="/images/courses/..." />
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="IsPublished" class="form-check-input" />
                            <label asp-for="IsPublished" class="form-check-label">Publish this course</label>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IssuesCertificate" class="form-check-input" />
                            <label asp-for="IssuesCertificate" class="form-check-label">Generate certificate on completion</label>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary-custom btn-lg">
                                <i class="bi bi-check-lg me-1"></i> @(Model.Id == 0 ? "Create Course" : "Save Changes")
                            </button>
                            <a asp-action="Courses" class="btn btn-outline-custom btn-lg">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
