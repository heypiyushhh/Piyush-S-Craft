@model AdminDashboardDto
@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["AdminPage"] = true;
}

<section class="page-header">
    <div class="container">
        <h1 class="page-title animate-slide-up">Admin Dashboard</h1>
        <p class="page-subtitle animate-slide-up" style="animation-delay: 0.2s">Manage your platform</p>
    </div>
</section>

<section class="section-padding">
    <div class="container">
        <!-- Stats -->
        <div class="row g-4 mb-5">
            <div class="col-md-3 col-6 scroll-reveal">
                <div class="stat-card">
                    <div class="stat-card-icon"><i class="bi bi-journal-code"></i></div>
                    <div class="stat-card-info">
                        <span class="stat-card-number">@Model.TotalCourses</span>
                        <span class="stat-card-label">Courses</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6 scroll-reveal" style="animation-delay: 0.1s">
                <div class="stat-card">
                    <div class="stat-card-icon"><i class="bi bi-people"></i></div>
                    <div class="stat-card-info">
                        <span class="stat-card-number">@Model.TotalStudents</span>
                        <span class="stat-card-label">Students</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6 scroll-reveal" style="animation-delay: 0.2s">
                <div class="stat-card">
                    <div class="stat-card-icon"><i class="bi bi-mortarboard"></i></div>
                    <div class="stat-card-info">
                        <span class="stat-card-number">@Model.TotalEnrollments</span>
                        <span class="stat-card-label">Enrollments</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6 scroll-reveal" style="animation-delay: 0.3s">
                <div class="stat-card @(Model.UnreadQueries > 0 ? "has-notification" : "")">
                    <div class="stat-card-icon"><i class="bi bi-envelope"></i></div>
                    <div class="stat-card-info">
                        <span class="stat-card-number">@Model.UnreadQueries</span>
                        <span class="stat-card-label">Unread Queries</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row g-4 mb-5">
            <div class="col-12 scroll-reveal">
                <h4 class="mb-3">Quick Actions</h4>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-action="Courses" class="btn btn-outline-custom">
                        <i class="bi bi-journal-code me-1"></i> Manage Courses
                    </a>
                    <a asp-action="CreateCourse" class="btn btn-primary-custom">
                        <i class="bi bi-plus-lg me-1"></i> Add New Course
                    </a>
                    <a asp-action="Students" class="btn btn-outline-custom">
                        <i class="bi bi-people me-1"></i> View Students
                    </a>
                    <a asp-action="Enrollments" class="btn btn-outline-custom">
                        <i class="bi bi-mortarboard me-1"></i> Enrollments
                    </a>
                    <a asp-action="Queries" class="btn btn-outline-custom @(Model.UnreadQueries > 0 ? "btn-notification" : "")">
                        <i class="bi bi-envelope me-1"></i> Queries
                        @if (Model.UnreadQueries > 0)
                        {
                            <span class="badge bg-danger ms-1">@Model.UnreadQueries</span>
                        }
                    </a>
                    <a asp-action="Projects" class="btn btn-outline-custom">
                        <i class="bi bi-briefcase me-1"></i> Manage Projects
                    </a>
                    <a asp-action="Skills" class="btn btn-outline-custom">
                        <i class="bi bi-stars me-1"></i> Manage Skills
                    </a>
                </div>
            </div>
        </div>

        <!-- Recent Enrollments -->
        <div class="scroll-reveal">
            <h4 class="mb-3">Recent Enrollments</h4>
            <div class="card-custom">
                @if (!Model.RecentEnrollments.Any())
                {
                    <p class="text-muted text-center py-3">No enrollments yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Course</th>
                                    <th>Status</th>
                                    <th>Progress</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in Model.RecentEnrollments)
                                {
                                    <tr>
                                        <td>
                                            <strong>@e.StudentName</strong><br />
                                            <small class="text-muted">@e.StudentEmail</small>
                                        </td>
                                        <td>@e.CourseTitle</td>
                                        <td>
                                            <span class="badge @(e.Status == EnrollmentStatus.Completed ? "bg-success" :
                                                e.Status == EnrollmentStatus.InProgress ? "bg-warning text-dark" : "bg-secondary")">
                                                @e.Status
                                            </span>
                                        </td>
                                        <td>
                                            <div class="progress" style="height: 6px; width: 100px; background: var(--bg-primary);">
                                                <div class="progress-bar" style="width: @e.ProgressPercent%"></div>
                                            </div>
                                            <small class="text-muted">@e.ProgressPercent%</small>
                                        </td>
                                        <td><small>@e.EnrolledAt.ToString("MMM dd, yyyy")</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
