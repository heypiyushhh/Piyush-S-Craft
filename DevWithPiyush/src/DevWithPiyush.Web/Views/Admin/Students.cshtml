@model IEnumerable<StudentDto>
@{
    ViewData["Title"] = "Manage Students";
    ViewData["AdminPage"] = true;
}

<section class="page-header">
    <div class="container">
        <h1 class="page-title animate-slide-up">Students</h1>
    </div>
</section>

<section class="section-padding">
    <div class="container">
        <div class="card-custom">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Enrolled Courses</th>
                            <th>Joined</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td><strong>@student.FullName</strong></td>
                                <td>@student.Email</td>
                                <td><span class="badge bg-secondary">@student.EnrolledCourses</span></td>
                                <td>@student.CreatedAt.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
