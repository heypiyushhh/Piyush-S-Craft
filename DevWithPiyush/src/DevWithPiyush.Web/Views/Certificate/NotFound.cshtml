@{
    ViewData["Title"] = "Certificate Not Found";
}

<section class="section-padding text-center d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 py-5">
                <div class="mb-4">
                    <i class="bi bi-shield-slash text-danger" style="font-size: 4.5rem; display: inline-block;"></i>
                </div>
                <h1 class="mb-3" style="font-size: 2.2rem; font-weight: 700; letter-spacing: -0.02em;">Invalid Credential</h1>
                <p class="text-muted mb-4" style="font-size: 1.1rem; line-height: 1.6; max-width: 600px; margin: 0 auto 30px auto;">
                    @ViewData["ErrorMessage"]
                </p>
                <a href="/" class="btn btn-primary-custom px-4 py-2">
                    <i class="bi bi-arrow-left me-2"></i> Go to Homepage
                </a>
            </div>
        </div>
    </div>
</section>
